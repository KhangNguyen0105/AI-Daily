DATABASE_URL=postgresql://aidaily:aidaily_dev@localhost:5432/aidaily
REDIS_HOST=localhost
REDIS_PORT=6379

# AI Provider (Mimo preferred, OpenModel fallback, then OpenAI/Anthropic)
MIMO_API_KEY=your-mimo-key-here
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro
OPENMODEL_API_KEY=your-openmodel-key-here
OPENMODEL_BASE_URL=https://api.openmodel.ai/v1
OPENMODEL_MODEL=mimo-v2.5-pro
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

NODE_ENV=development

# Consumer Subscription Crawler Credentials (optional — for login-based crawling)
# Set these to enable authenticated crawling for providers that require login
POE_EMAIL=
POE_PASSWORD=
OPENAI_EMAIL=
OPENAI_PASSWORD=
MS_EMAIL=
MS_PASSWORD=
GOOGLE_EMAIL=
GOOGLE_PASSWORD=
X_EMAIL=
X_PASSWORD=

# Admin Authentication (Phase 8)
ADMIN_PASSWORD=your-strong-admin-password
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
